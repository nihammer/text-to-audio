models/
!models/.gitkeep

# ─── User-provided audio ──────────────────────────────────
reference/
!reference/.gitkeep

# ─── Runtime artifacts ────────────────────────────────────
cache/
!cache/.gitkeep

checkpoints/
!checkpoints/.gitkeep

# ─── Generated output ─────────────────────────────────────
output/
!output/.gitkeep

# ─── Binary / audio files ─────────────────────────────────
*.mp3
*.wav
*.flac
*.onnx
*.safetensors
*.npy
*.pt
*.bin

# ─── IDE ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
