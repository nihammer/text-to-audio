# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/

# ─── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Large model files ────────────────────────────────────
